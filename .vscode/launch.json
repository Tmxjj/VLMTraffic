{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python 调试程序: 当前文件",  // <--- 1. 这里补上了逗号
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "env": {
                // 注意：Linux/Mac 用冒号(:)分隔，Windows 用分号(;)分隔
                "PYTHONPATH": "${env:PYTHONPATH}:${workspaceFolder}/src" 
            }
        }
    ]
}