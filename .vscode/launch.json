{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python 调试: 附加到 Accelerate (端口 5679)",
            "type": "debugpy",
            "request": "attach",
            "connect": {
                "host": "localhost",
                "port": 5679
            },
            "pathMappings": [
                {
                    "localRoot": "${workspaceFolder}",
                    "remoteRoot": "${workspaceFolder}"
                }
            ],
            "justMyCode": false 
        },
        {
            "name": "Python 调试: VirtualGL (GPU 加速 + BEV)",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "python": "${workspaceFolder}/vgl_python.sh",
            "env": {
                "PYTHONPATH": "${env:PYTHONPATH}:${workspaceFolder}/src" 
            }
        },
        {
            "name": "Python 调试: 普通当前文件",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${env:PYTHONPATH}:${workspaceFolder}/src" 
            }
        }
    ]
}